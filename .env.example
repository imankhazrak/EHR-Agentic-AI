# Copy to .env in the repo root (never commit .env).

OPENAI_API_KEY=sk-...

# Optional: override configs/default.yaml llm.model
# OPENAI_MODEL=gpt-4o-mini
# LLM_MODEL=gpt-4o-mini

# Optional: OpenAI-compatible base URL (proxy / Azure-style gateway)
# OPENAI_BASE_URL=

# Optional org/project headers (OpenAI Cloud user keys)
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=

# Optional other providers if you change llm.provider in YAML:
# ANTHROPIC_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=
